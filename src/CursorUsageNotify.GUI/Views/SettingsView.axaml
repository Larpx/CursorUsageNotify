<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Larpx.PersonalTools.CursorUsageNotify.GUI.ViewModels"
             xmlns:conv="using:Larpx.PersonalTools.CursorUsageNotify.GUI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Larpx.PersonalTools.CursorUsageNotify.GUI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Resources>
        <conv:SuccessToColorConverter x:Key="SuccessToColor"/>
    </UserControl.Resources>

    <ScrollViewer Padding="24,24,24,40" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical" Spacing="16" MaxWidth="640">

            <!-- Cursor Cookie 认证区 -->
            <Border BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Vertical" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox IsChecked="{Binding CursorEnabled, Mode=TwoWay}"/>
                        <TextBlock Text="Cursor 平台" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="勾选启用数据采集；取消后停止刷新但保留历史数据。"
                               FontSize="11" Foreground="#FF9CA3AF"/>

                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="Cookie（从浏览器 F12 → 应用 → Cookie 中复制完整 Cookie 字符串）" FontSize="12" Foreground="#FF6B7280"/>
                        <TextBox Text="{Binding InputToken, Mode=TwoWay}"
                                 PasswordChar="●"
                                 PlaceholderText="粘贴 WorkosCursorSessionToken=xxx 或完整 Cookie"
                                 AcceptsReturn="False"/>
                        <TextBlock Text="支持直接粘贴完整 Cookie 字符串，自动解析 WorkosCursorSessionToken"
                                   FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding TokenMaskedDisplay}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#FF16A34A"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="测试连接"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding !IsTesting}"/>
                        <Button Content="打开浏览器登录 Cursor"
                                Command="{Binding OpenBrowserCommand}"/>
                        <Button Content="清除 Token"
                                Command="{Binding ClearTokenCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding TestResult}"
                               FontSize="13"
                               Foreground="{Binding TestSuccess, Converter={StaticResource SuccessToColor}}"/>
                </StackPanel>
            </Border>

            <!-- DeepSeek userToken 认证区 -->
            <Border BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Vertical" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox IsChecked="{Binding DeepSeekEnabled, Mode=TwoWay}"/>
                        <TextBlock Text="DeepSeek 平台" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="勾选启用数据采集；取消后停止刷新但保留历史数据。"
                               FontSize="11" Foreground="#FF9CA3AF"/>

                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="userToken（从浏览器 F12 → Application → Local Storage → userToken 复制）"
                                   FontSize="12" Foreground="#FF6B7280"/>
                        <TextBox Text="{Binding DeepSeekInputToken, Mode=TwoWay}"
                                 PasswordChar="●"
                                 PlaceholderText="粘贴 userToken JSON 或裸 token"
                                 AcceptsReturn="False"/>
                        <TextBlock Text="支持粘贴完整 localStorage userToken JSON（自动提取 value）或直接粘贴 token 值"
                                   FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding DeepSeekTokenMaskedDisplay}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#FF16A34A"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="测试连接"
                                Command="{Binding TestDeepSeekConnectionCommand}"
                                IsEnabled="{Binding !IsDeepSeekTesting}"/>
                        <Button Content="打开 DeepSeek 平台"
                                Command="{Binding OpenDeepSeekBrowserCommand}"/>
                        <Button Content="清除 Token"
                                Command="{Binding ClearDeepSeekTokenCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding DeepSeekTestResult}"
                               FontSize="13"
                               Foreground="{Binding DeepSeekTestSuccess, Converter={StaticResource SuccessToColor}}"/>
                </StackPanel>
            </Border>

            <!-- 间隔设置区 -->
            <Border BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Vertical" Spacing="12">
                    <TextBlock Text="定时设置" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="数据拉取间隔" FontSize="12" Foreground="#FF6B7280"/>
                        <ComboBox ItemsSource="{Binding IntervalOptions}"
                                  SelectedItem="{Binding SyncIntervalMinutes}"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="通知间隔（分钟）" FontSize="12" Foreground="#FF6B7280"/>
                        <ComboBox ItemsSource="{Binding IntervalOptions}"
                                  SelectedItem="{Binding NotificationIntervalMinutes}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="保存设置" Command="{Binding SaveSettingsCommand}"/>
                        <Button Content="立即拉取一次"
                                Command="{Binding SyncNowCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 危险操作区 -->
            <Border BorderBrush="#FFFECACA" BorderThickness="1" CornerRadius="8" Padding="16" Background="#FFFEF2F2">
                <StackPanel Orientation="Vertical" Spacing="12">
                    <TextBlock Text="数据管理" FontSize="16" FontWeight="SemiBold" Foreground="#FFB91C1C"/>
                    <TextBlock Text="清空所有平台历史用量数据，此操作不可撤销。" FontSize="12" Foreground="#FF7F1D1D"/>
                    <Button Content="清空历史数据"
                            Command="{Binding ClearDataCommand}"
                            Background="#FFEF4444"
                            Foreground="White"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
