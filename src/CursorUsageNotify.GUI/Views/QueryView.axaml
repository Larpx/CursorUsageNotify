<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Larpx.PersonalTools.CursorUsageNotify.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Larpx.PersonalTools.CursorUsageNotify.GUI.Views.QueryView"
             x:DataType="vm:QueryViewModel">

    <DockPanel LastChildFill="True">

        <!-- 顶部筛选区 -->
        <Border DockPanel.Dock="Top" Padding="16,12" Background="#FFF9FAFB" BorderBrush="#FFE5E7EB" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical" Spacing="6">
                <!-- 第一行：日期 + 模型筛选 -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="起始：" VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding StartTime}"/>

                    <TextBlock Text="结束：" VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding EndTime}"/>

                    <TextBlock Text="模型：" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding Models}"
                              SelectedItem="{Binding SelectedModel}"
                              PlaceholderText="全部"
                              MinWidth="160"/>
                </StackPanel>

                <!-- 第二行：操作按钮（靠右） -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="重置" Command="{Binding ResetModelCommand}" ToolTip.Tip="取消模型筛选，显示全部"/>
                    <Button Content="查询" Command="{Binding LoadCommand}"/>
                    <Button Content="导出 CSV" Command="{Binding ExportCsvCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 底部：分页导航 + 每页行数 + 状态 -->
        <Border DockPanel.Dock="Bottom" Padding="12,6" Background="#FFF3F4F6" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左：每页行数选择 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="每页" FontSize="12" Foreground="#FF4B5563" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding PageSizeOptionList}"
                              SelectedItem="{Binding PageSize}"
                              MinWidth="70"
                              FontSize="12"/>
                    <TextBlock Text="行" FontSize="12" Foreground="#FF4B5563" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 中：分页摘要 -->
                <TextBlock Grid.Column="1" Text="{Binding PageSummary}" FontSize="12" Foreground="#FF4B5563"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- 右：翻页按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="◀ 上一页"
                            Command="{Binding GoPrevCommand}"
                            IsEnabled="{Binding CanGoPrev}"
                            FontSize="12"
                            Padding="8,2"/>
                    <Button Content="下一页 ▶"
                            Command="{Binding GoNextCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            FontSize="12"
                            Padding="8,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid：数据预计算为字符串，无转换器调用，滚动零开销 -->
        <DataGrid ItemsSource="{Binding Events}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="#FFE5E7EB"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间"
                                    Binding="{Binding FormattedTimestamp}"
                                    Width="170"/>
                <DataGridTextColumn Header="模型" Binding="{Binding Model}" Width="180"/>
                <DataGridTextColumn Header="输入 Token" Binding="{Binding FormattedInputTokens}" Width="110"/>
                <DataGridTextColumn Header="输出 Token" Binding="{Binding FormattedOutputTokens}" Width="110"/>
                <DataGridTextColumn Header="缓存读" Binding="{Binding FormattedCacheReadTokens}" Width="110"/>
                <DataGridTextColumn Header="缓存写" Binding="{Binding FormattedCacheWriteTokens}" Width="110"/>
                <DataGridTextColumn Header="费用"
                                    Binding="{Binding FormattedCost}"
                                    Width="90"/>
                <DataGridCheckBoxColumn Header="Max" Binding="{Binding MaxMode}" Width="60"/>
                <DataGridCheckBoxColumn Header="Headless" Binding="{Binding IsHeadless}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

</UserControl>