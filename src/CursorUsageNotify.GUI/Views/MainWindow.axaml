<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Larpx.PersonalTools.CursorUsageNotify.GUI.ViewModels"
        xmlns:conv="using:Larpx.PersonalTools.CursorUsageNotify.GUI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="Larpx.PersonalTools.CursorUsageNotify.GUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/app.ico"
        Title="Cursor用量统计  v1.0.0  -  by Larpx"
        Width="1200" Height="550"
        MinWidth="1000" MinHeight="550"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:CentsToCurrencyConverter x:Key="CentsToCurrency"/>
        <conv:EpochToDateTimeConverter x:Key="EpochToDate"/>
        <conv:TokenFormatConverter x:Key="TokenFormat"/>
    </Window.Resources>

    <!-- 格式切换按钮样式：hover/pressed 保持深灰底白字 -->
    <Window.Styles>
        <!-- 默认 -->
        <Style Selector="Button.TokenFormatBtn">
            <Setter Property="Background" Value="#FF374151"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- hover -->
        <Style Selector="Button.TokenFormatBtn:pointerover">
            <Setter Property="Background" Value="#FF4B5563"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- pressed -->
        <Style Selector="Button.TokenFormatBtn:pressed">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 大屏刷新按钮：深灰底白图标，hover/pressed 与 TokenFormatBtn 风格一致 -->
        <Style Selector="Button.RefreshBtn">
            <Setter Property="Background" Value="#FF374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.RefreshBtn:pointerover">
            <Setter Property="Background" Value="#FF4B5563"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.RefreshBtn:pressed">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.RefreshBtn:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- 同步进度条：IsSyncing 为 true 时显示滚动动画，避免误以为卡顿 -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsSyncing}"
                     Height="3"
                     Minimum="0" Maximum="100"
                     Foreground="#FF60A5FA"
                     Background="Transparent"/>

        <!-- Cookie 有效性预警条：临近过期或已失效时显示，提醒用户更新 cookie -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasCookieWarning}"
                Background="#3f1d1d"
                Padding="24,6">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding CookieStatusColor}"/>
                    <TextBlock Text="{Binding CookieStatusText}" FontSize="12" Foreground="#FFFCA5A5"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="打开浏览器"
                            Command="{Binding OpenBrowserCommand}"
                            Padding="8,2" FontSize="11"
                            Background="#FFB91C1C" Foreground="White"/>
                    <Button Content="立即更新"
                            Command="{Binding OpenSettingsCommand}"
                            Padding="8,2" FontSize="11"
                            Background="#FFB91C1C" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 顶部数据大屏：双列布局，每列一个平台 -->
        <Border DockPanel.Dock="Top" Background="#FF1F2937" Padding="16,12">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <!-- Cursor 平台列 -->
                <Border Grid.Column="0" BorderBrush="#FF374151" BorderThickness="1" CornerRadius="8" Padding="12,10"
                        IsVisible="{Binding CursorDashboard.IsEnabled}">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <!-- 平台标题 -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CursorDashboard.PlatformName}" FontSize="15" FontWeight="SemiBold" Foreground="#FF60A5FA"/>
                            <TextBlock Text="{Binding CursorDashboard.PlanName, StringFormat=（{0}）}" FontSize="11" Foreground="#FF9CA3AF"/>
                        </StackPanel>

                        <!-- 账户信息行 -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="100">
                                <TextBlock Text="用户" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CursorDashboard.DisplayName}" FontSize="12" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="140">
                                <TextBlock Text="邮箱" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CursorDashboard.Email}" FontSize="12" Foreground="#FFD1D5DB"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="180">
                                <TextBlock Text="订阅周期" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CursorDashboard.PeriodRange}" FontSize="12" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="60">
                                <TextBlock Text="状态" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CursorDashboard.SubStatus}" FontSize="12" Foreground="#FFD1D5DB"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 当天用量 -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="当天用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodayInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF93C5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodayOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF86EFAC"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodayCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFDE047"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存写" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodayCacheWriteTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFC4B5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodayTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF67E8F9"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.TodaySpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFCA5A5"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 本周用量 -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="本周用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF93C5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF86EFAC"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFDE047"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存写" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekCacheWriteTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFC4B5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF67E8F9"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.WeekSpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFCA5A5"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 本周期用量 -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="本周期用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF60A5FA"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF34D399"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFBBF24"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存写" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodCacheWriteTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF22D3EE"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding CursorDashboard.PeriodSpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFF87171"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DeepSeek 平台列 -->
                <Border Grid.Column="1" BorderBrush="#FF374151" BorderThickness="1" CornerRadius="8" Padding="12,10"
                        IsVisible="{Binding DeepSeekDashboard.IsEnabled}">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <!-- 平台标题 -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DeepSeekDashboard.PlatformName}" FontSize="15" FontWeight="SemiBold" Foreground="#FF34D399"/>
                            <TextBlock Text="{Binding DeepSeekDashboard.PlanName, StringFormat=（{0}）}" FontSize="11" Foreground="#FF9CA3AF"/>
                        </StackPanel>

                        <!-- 账户信息行（无订阅周期/状态，DeepSeek 按自然月） -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="100">
                                <TextBlock Text="用户" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding DeepSeekDashboard.DisplayName}" FontSize="12" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="1" MinWidth="180">
                                <TextBlock Text="本月周期" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding DeepSeekDashboard.PeriodRange}" FontSize="12" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 当天用量（无缓存写入） -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="当天用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.TodayInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF93C5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.TodayOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF86EFAC"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.TodayCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFDE047"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.TodayTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF67E8F9"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用(¥)" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.TodaySpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFCA5A5"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 本周用量 -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="本周用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.WeekInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF93C5FD"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.WeekOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF86EFAC"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.WeekCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFDE047"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.WeekTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF67E8F9"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用(¥)" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.WeekSpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFCA5A5"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 本月用量 -->
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="本月用量" FontSize="10" FontWeight="SemiBold" Foreground="#FF9CA3AF"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输入" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.PeriodInputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF60A5FA"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="输出" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.PeriodOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF34D399"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="缓存读" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.PeriodCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFBBF24"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="90">
                                    <TextBlock Text="总用量" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.PeriodTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="13" FontWeight="SemiBold" Foreground="#FF22D3EE"/>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="1" MinWidth="80">
                                    <TextBlock Text="费用(¥)" FontSize="9" Foreground="#FF6B7280"/>
                                    <TextBlock Text="{Binding DeepSeekDashboard.PeriodSpend, StringFormat={}{0:F2}}" FontSize="13" FontWeight="SemiBold" Foreground="#FFF87171"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- 底部状态栏：刷新 + 切换单位按钮 + 状态灯（hover 显示各平台同步状态）+ 状态文本 -->
        <Border DockPanel.Dock="Bottom" Background="#FFF3F4F6" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左：操作按钮 + 状态灯 + 状态文本 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- 立即刷新按钮 -->
                    <Button Classes="RefreshBtn"
                            Width="32" Height="32"
                            Padding="0"
                            Command="{Binding RefreshNowCommand}"
                            IsEnabled="{Binding !IsSyncing}"
                            ToolTip.Tip="立即刷新所有启用平台">
                        <Path Width="18" Height="18"
                              Stretch="Uniform"
                              Fill="White"
                              Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                    </Button>

                    <!-- 切换单位按钮 -->
                    <Button Classes="TokenFormatBtn"
                            Command="{Binding CycleTokenFormatCommand}"
                            Content="{Binding TokenFormatLabel}"
                            ToolTip.Tip="切换 Token 显示格式：全部 / 万 / 百万"
                            Padding="10,4"
                            FontSize="12"
                            VerticalAlignment="Center"/>

                    <!-- 状态灯（带 tooltip 显示各平台同步状态和时间） -->
                    <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}"
                             ToolTip.Tip="{Binding StatusTooltip}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#FF1F2937" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右：留空（原同步时间已移除，移到状态灯 tooltip） -->
                <TextBlock Grid.Column="2" Text="" FontSize="12"/>
            </Grid>
        </Border>

        <!-- TabControl：LastChildFill 自动填充剩余空间 -->
        <TabControl x:Name="MainTabs" Padding="0">
            <TabItem Header="查询">
                <ContentControl x:Name="QueryTabContent" Content="{Binding .}"/>
            </TabItem>
            <TabItem Header="设置">
                <ContentControl x:Name="SettingsTabContent" Content="{Binding .}"/>
            </TabItem>
        </TabControl>

    </DockPanel>

</Window>
