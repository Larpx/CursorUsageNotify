<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Larpx.PersonalTools.CursorUsageNotify.GUI.ViewModels"
        xmlns:conv="using:Larpx.PersonalTools.CursorUsageNotify.GUI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="Larpx.PersonalTools.CursorUsageNotify.GUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/app.ico"
        Title="Cursor用量统计  v1.0.0  -  by Larpx"
        Width="1200" Height="550"
        MinWidth="1000" MinHeight="550"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:CentsToCurrencyConverter x:Key="CentsToCurrency"/>
        <conv:EpochToDateTimeConverter x:Key="EpochToDate"/>
        <conv:TokenFormatConverter x:Key="TokenFormat"/>
    </Window.Resources>

    <!-- 格式切换按钮样式：hover/pressed 保持深灰底白字 -->
    <Window.Styles>
        <!-- 默认 -->
        <Style Selector="Button.TokenFormatBtn">
            <Setter Property="Background" Value="#FF374151"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- hover -->
        <Style Selector="Button.TokenFormatBtn:pointerover">
            <Setter Property="Background" Value="#FF4B5563"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- pressed -->
        <Style Selector="Button.TokenFormatBtn:pressed">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.TokenFormatBtn:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- 同步进度条：IsSyncing 为 true 时显示滚动动画，避免误以为卡顿 -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsSyncing}"
                     Height="3"
                     Minimum="0" Maximum="100"
                     Foreground="#FF60A5FA"
                     Background="Transparent"/>

        <!-- Cookie 有效性预警条：临近过期或已失效时显示，提醒用户更新 cookie -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasCookieWarning}"
                Background="#3f1d1d"
                Padding="24,6">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding CookieStatusColor}"/>
                    <TextBlock Text="{Binding CookieStatusText}" FontSize="12" Foreground="#FFFCA5A5"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="打开浏览器"
                            Command="{Binding OpenBrowserCommand}"
                            Padding="8,2" FontSize="11"
                            Background="#FFB91C1C" Foreground="White"/>
                    <Button Content="立即更新"
                            Command="{Binding OpenSettingsCommand}"
                            Padding="8,2" FontSize="11"
                            Background="#FFB91C1C" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 顶部数据大屏 -->
        <Border DockPanel.Dock="Top" Background="#FF1F2937" Padding="24,14">
            <StackPanel Orientation="Vertical" Spacing="10">

                <!-- 第一行：用户名(含订阅类型) + 订阅起始 + 订阅结束 + 订阅状态 + 发票数 -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Vertical" Spacing="2" MinWidth="120">
                        <TextBlock Text="用户" FontSize="11" Foreground="#FF9CA3AF"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserDisplayName}" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{Binding PlanName, StringFormat=（{0}）}" FontSize="12" Foreground="#FF60A5FA"/>
                        </StackPanel>
                        <!-- <TextBlock Text="{Binding UserEmail}" FontSize="10" Foreground="#FF9CA3AF"/> -->
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="2" MinWidth="120">
                        <TextBlock Text="订阅周期" FontSize="11" Foreground="#FF9CA3AF"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SubStartDate}" FontSize="13" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                            <TextBlock Text=" - " FontSize="13" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                            <TextBlock Text="{Binding SubEndDate}" FontSize="13" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- <StackPanel Orientation="Vertical" Spacing="2" MinWidth="160">
                        <TextBlock Text="订阅结束" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding SubEndDate}" FontSize="14" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                    </StackPanel> -->

                    <StackPanel Orientation="Vertical" Spacing="2" MinWidth="100">
                        <TextBlock Text="订阅状态" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding SubStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="2" MinWidth="80">
                        <TextBlock Text="发票数" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding InvoiceCount}" FontSize="14" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                    </StackPanel>

                    <!-- Token 格式切换按钮 -->
                    <Button Classes="TokenFormatBtn"
                            Command="{Binding CycleTokenFormatCommand}"
                            Content="{Binding TokenFormatLabel}"
                            ToolTip.Tip="切换 Token 显示格式：全部 / 万 / 百万"
                            Padding="10,4"
                            FontSize="12"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 第二行：本周用量 -->
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock Text="本周用量" FontSize="11" FontWeight="SemiBold" Foreground="#FF9CA3AF" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="输入 Token" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekInputTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF93C5FD"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="输出 Token" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF86EFAC"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="缓存读取" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFDE047"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="缓存写入" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekCacheWriteTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFC4B5FD"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="160">
                            <TextBlock Text="总用量" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF67E8F9"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="140">
                            <TextBlock Text="费用" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding WeekSpendDollars, StringFormat=\${0:F2}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFCA5A5"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 第三行：本周期用量 -->
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock Text="本周期用量" FontSize="11" FontWeight="SemiBold" Foreground="#FF9CA3AF" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="输入 Token" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodInputTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF60A5FA"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="输出 Token" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodOutputTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF34D399"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="缓存读取" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodCacheReadTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFBBF24"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="150">
                            <TextBlock Text="缓存写入" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodCacheWriteTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="160">
                            <TextBlock Text="总用量" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodTotalTokens, Converter={StaticResource TokenFormat}}" FontSize="16" FontWeight="SemiBold" Foreground="#FF22D3EE"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="1" MinWidth="140">
                            <TextBlock Text="费用" FontSize="10" Foreground="#FF6B7280"/>
                            <TextBlock Text="{Binding PeriodSpendDollars, StringFormat=\${0:F2}}" FontSize="16" FontWeight="SemiBold" Foreground="#FFF87171"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 底部状态栏：状态灯 + 状态文本（含报错） + 最近拉取时间 -->
        <Border DockPanel.Dock="Bottom" Background="#FFF3F4F6" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左：状态灯 + 状态文本（报错时显示错误信息） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#FF1F2937" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右：最近拉取时间 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="最近拉取：" FontSize="12" Foreground="#FF6B7280" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastFetchTime}" FontSize="12" Foreground="#FF1F2937" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TabControl：LastChildFill 自动填充剩余空间 -->
        <TabControl x:Name="MainTabs" Padding="0">
            <TabItem Header="查询">
                <ContentControl x:Name="QueryTabContent" Content="{Binding .}"/>
            </TabItem>
            <TabItem Header="设置">
                <ContentControl x:Name="SettingsTabContent" Content="{Binding .}"/>
            </TabItem>
        </TabControl>

    </DockPanel>

</Window>
