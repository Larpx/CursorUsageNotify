<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CursorUsageNotify.GUI.ViewModels"
        xmlns:conv="using:CursorUsageNotify.GUI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="CursorUsageNotify.GUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/app.ico"
        Title="Cursor 用量通知"
        Width="900" Height="650"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:CentsToCurrencyConverter x:Key="CentsToCurrency"/>
        <conv:EpochToDateTimeConverter x:Key="EpochToDate"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- 顶部数据大屏 -->
        <Border DockPanel.Dock="Top" Background="#FF1F2937" Padding="24,16">
            <StackPanel Orientation="Vertical" Spacing="12">

                <!-- 第一行：用户信息 + 周期 + 拉取时间 + 状态 -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="用户" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding UserEmail}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding PlanName}" FontSize="13" Foreground="#FFD1D5DB"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="订阅周期" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding PeriodRange}" FontSize="14" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="最近拉取" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding LastFetchTime}" FontSize="14" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="状态" FontSize="12" Foreground="#FF9CA3AF"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 第二行：用量统计 -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="已用 Token" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding UsedTokens, StringFormat=\{0:N0\}}" FontSize="20" FontWeight="SemiBold" Foreground="#FF60A5FA"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="已用请求" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding UsedRequests, StringFormat=\{0:N0\}}" FontSize="20" FontWeight="SemiBold" Foreground="#FF34D399"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="剩余请求" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding RemainingRequests, StringFormat=\{0:N0\}}" FontSize="20" FontWeight="SemiBold" Foreground="#FFFBBF24"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="本周期支出" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding TotalSpendDollars, StringFormat=\${0:F2}}" FontSize="20" FontWeight="SemiBold" Foreground="#FFF87171"/>
                    </StackPanel>
                </StackPanel>

                <!-- 第三行：订阅信息 -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="180">
                        <TextBlock Text="订阅起始" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding SubStartDate}" FontSize="14" FontWeight="SemiBold" Foreground="#FFA78BFA"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="140">
                        <TextBlock Text="订阅状态" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding SubStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="100">
                        <TextBlock Text="发票数" FontSize="12" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding InvoiceCount}" FontSize="14" FontWeight="SemiBold" Foreground="#FFD1D5DB"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- TabControl -->
        <TabControl x:Name="MainTabs" Padding="0">
            <TabItem Header="查询">
                <ContentControl x:Name="QueryTabContent" Content="{Binding .}"/>
            </TabItem>
            <TabItem Header="设置">
                <ContentControl x:Name="SettingsTabContent" Content="{Binding .}"/>
            </TabItem>
        </TabControl>

    </DockPanel>

</Window>
